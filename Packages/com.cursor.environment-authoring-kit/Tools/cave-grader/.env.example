# Copy to .env (gitignored) and paste your key from cursor.com/dashboard/cloud-agents
CURSOR_API_KEY=crsr_your_key_here
# Optional provider keys for Hub routing/external workflows
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
CUSTOM_API_KEY=
# Unity project root (must contain Assets/). Do NOT use /path/to/Hub from docs.
HUB_ROOT=/Users/jacob/Hub
# Local executor model (try auto if local runs error immediately)
CAVE_CURSOR_MODEL=auto
CAVE_AI_PROVIDER=Cursor
# External provider execution layer (non-Cursor only):
# 1 = allow file edits from structured JSON output, 0 = do not write files.
CAVE_EXTERNAL_APPLY_EDITS=0
# 1 = preview only (recommended initially), 0 = write to disk.
CAVE_EXTERNAL_APPLY_DRY_RUN=1
# Optional local/OpenAI-compatible endpoint for non-Cursor provider experiments
# CAVE_ACTIVE_BASE_URL=http://localhost:11434/v1
# Optional: cloud fallback when local agent fails (Hub must be pushed to this remote)
# CAVE_CURSOR_REPO_URL=https://github.com/you/Hub.git
